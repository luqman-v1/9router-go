# 9router-go environment contract
# Copy to .env and fill in values.

# Required
JWT_SECRET=change-me-to-a-long-random-secret
INITIAL_PASSWORD=change-me
DATA_DIR=/var/lib/9router

# Server
PORT=20128

# OAuth client credentials
# Set these to override built-in defaults. Hardcoded fallbacks exist for
# well-known public clients (antigravity, gemini-cli, xai, codex, iflow, etc.)
# so most users don't need to touch these.
# ANTIGRAVITY_OAUTH_CLIENT_ID=
# ANTIGRAVITY_OAUTH_CLIENT_SECRET=
# GEMINI_CLI_OAUTH_CLIENT_ID=
# GEMINI_CLI_OAUTH_CLIENT_SECRET=
# XAI_OAUTH_CLIENT_ID=
# XAI_OAUTH_CLIENT_SECRET=
# CODEX_OAUTH_CLIENT_ID=
# CODEX_OAUTH_CLIENT_SECRET=
# GITHUB_OAUTH_CLIENT_ID=
# GITHUB_OAUTH_CLIENT_SECRET=
# IFLOW_OAUTH_CLIENT_ID=
# IFLOW_OAUTH_CLIENT_SECRET=
# KIMI_CODING_OAUTH_CLIENT_ID=
# KIMI_CODING_OAUTH_CLIENT_SECRET=
# QWEN_OAUTH_CLIENT_ID=
# QWEN_OAUTH_CLIENT_SECRET=
# QODER_OAUTH_CLIENT_ID=
# QODER_OAUTH_CLIENT_SECRET=

# Outbound proxy (optional)
# HTTP_PROXY=
# HTTPS_PROXY=
